{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "http-server D:\\portfolio :8080",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", "D:\\portfolio", "-p", "8080", "-c-1"],
      "port": 8080
    },
    {
      "name": "serve D:\\portfolio :3000",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "D:\\portfolio", "-l", "3000"],
      "port": 3000
    },
    {
      "name": "Python HTTP D:\\portfolio :8000",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000", "--directory", "D:\\portfolio"],
      "port": 8000
    }
  ]
}
